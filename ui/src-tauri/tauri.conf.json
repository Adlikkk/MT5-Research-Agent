{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MT5 Research Agent",
  "version": "0.1.1",
  "identifier": "com.mt5researchagent.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MT5 Research Agent",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.png"],
    "externalBin": ["binaries/mt5-research-agent-backend"]
  }
}
