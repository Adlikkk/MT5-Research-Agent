# MT5 Research Agent — optional AI provider keys.
#
# AI is OFF by default and the whole tool works without any of these.
# Keys are read from the environment at call time and are NEVER stored in
# config.json. Copy this file to a private location, fill in only the provider
# you use, and load it into your shell (this file's actual ".env" is gitignored).
#
# Enable a provider with, e.g.:
#   mt5-research-agent ai-config --provider openai --model gpt-4o-mini --enable

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
# Ollama runs locally and needs no key.
# Custom OpenAI-compatible endpoints default to AI_API_KEY:
AI_API_KEY=
